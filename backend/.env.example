DAI_APP_NAME=DAI Experiment Platform API
DAI_ENVIRONMENT=development
DAI_DATABASE_URL=mysql+pymysql://dai:dai_password@localhost:3306/dai_platform
DAI_REDIS_URL=redis://localhost:6379/0
DAI_SECRET_KEY=replace-with-a-long-random-secret
DAI_ACCESS_TOKEN_EXPIRE_MINUTES=30
DAI_REFRESH_TOKEN_EXPIRE_DAYS=7
DAI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DAI_JUPYTER_BASE_URL=http://localhost:8888
DAI_JUDGE_QUEUE_NAME=judge:queue
DAI_JUDGE_IMAGE=dai-judge-python:latest
DAI_JUDGE_USE_DOCKER=true
DAI_JUDGE_TIMEOUT_SECONDS=10
DAI_JUDGE_MEMORY_LIMIT_MB=256
DAI_JUDGE_CPU_LIMIT=1
